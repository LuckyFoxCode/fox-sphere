# Copy to `.env.prod` ON THE VM (never commit it). Compose reads it for `backend`.
# ==============================================================================
# EDGE / NETWORKING
# ==============================================================================
# ":80" = plain HTTP on the raw Oracle IP (start here).
# Later: set to the domain (e.g. overlay.luckyfox.dev) for automatic HTTPS.
SITE_ADDRESS=:80

# Where the overlay connects FROM = the Socket.io CORS allow-list.
# Option B (overlay served by the VM, same-origin): the site URL.
#   IP now:   http://<ORACLE_PUBLIC_IP>
#   Domain:   https://overlay.example.com
# Option A (overlay on Cloudflare Pages): the Pages URL.
ALLOWED_ORIGIN=http://CHANGE_ME

# ==============================================================================
# POSTGRES (compose creates this DB; DATABASE_URL is derived in compose)
# ==============================================================================
POSTGRES_USER=fox_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=foxsphere_db

# ==============================================================================
# APP
# ==============================================================================
PORT=3000
NODE_ENV=production
DEBUG=false
COMMAND_PREFIX=!t

# ==============================================================================
# TWITCH (same values as apps/backend/.env — see .env.example)
# ==============================================================================
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

TWITCH_USER_ID=99200545
TWITCH_CHANNEL_NAME=luckyfoxcode
TWITCH_STREAMER_ACCESS_TOKEN=your_streamer_access_token
TWITCH_STREAMER_REFRESH_TOKEN=your_streamer_refresh_token

TWITCH_BOT_ID=1502579014
TWITCH_BOT_ACCESS_TOKEN=your_bot_access_token
TWITCH_BOT_REFRESH_TOKEN=your_bot_refresh_token
