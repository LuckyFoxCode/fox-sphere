# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
PORT=3000
NODE_ENV=development
DEBUG=true

# Allowed origin for Socket.io and Express CORS (your Vue 3 Vite dev server)
ALLOWED_ORIGIN="http://localhost:5173"

# Database connection string for Prisma ORM
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ==============================================================================
# TWITCH DEVELOPER APPLICATION (Twitch Console)
# ==============================================================================
# Single Client ID and Secret shared by both Streamer and Bot accounts
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# ==============================================================================
# TWITCH STREAMER (BROADCASTER) ACCOUNT
# ==============================================================================
# Twitch User ID for 'luckyfoxcode'
TWITCH_USER_ID=99200545
TWITCH_CHANNEL_NAME=luckyfoxcode

# Tokens generated with required scopes (e.g., channel:manage:vips, moderation:read)
TWITCH_STREAMER_ACCESS_TOKEN=your_streamer_access_token
TWITCH_STREAMER_REFRESH_TOKEN=your_streamer_refresh_token

# ==============================================================================
# TWITCH BOT ACCOUNT
# ==============================================================================
# Twitch User ID for the bot account
TWITCH_BOT_ID=1502579014

# Tokens generated for the bot account (e.g., chat:read, chat:edit)
TWITCH_BOT_ACCESS_TOKEN=your_bot_access_token
TWITCH_BOT_REFRESH_TOKEN=your_bot_refresh_token