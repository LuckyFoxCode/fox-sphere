# Server Configuration
PORT=3000

# Database Configuration (PostgreSQL + Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Twitch Application Credentials (from dev.twitch.tv)
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Target Stream Channel
TWITCH_CHANNEL_NAME=your_twitch_stream_channel_name

# Twitch Bot Tokens (generated via TwitchTokenGenerator for Bot Account)
TWITCH_BOT_ACCESS_TOKEN=your_bot_access_token
TWITCH_BOT_REFRESH_TOKEN=your_bot_refresh_token